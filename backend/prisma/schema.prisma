generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id Int @id @default(autoincrement())

  email String @unique
  username String? @unique
  password String?

  googleId String? @unique

  name String? @db.VarChar(120)

  avatarKey String?

  provider AuthProvider @default(LOCAL)

  isVerified Boolean @default(false)

  otp       String?
  otpExpiry DateTime?

  resetToken    String?
  resetTokenExp DateTime?

  createdAt DateTime @default(now())

  channel       Channel?
  s3Credentials S3Credential[]
  videoActions  VideoAction[]
  playlists     Playlist[]

  @@index([name])
}

model Channel {
  id          Int      @id @default(autoincrement())
  name        String
  username    String   @unique
  description String?

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  videos Video[]

  createdAt DateTime @default(now())
}


model Video {
  id           Int          @id @default(autoincrement())

  publicId     String       @unique @db.VarChar(12) // ✅ ADD THIS

  title        String
  s3Key        String       @unique
  size         BigInt
  thumbnailKey String?

  uploadSource UploadSource
  status       UploadStatus @default(UPLOADING)

  visibility   VideoVisibility @default(PUBLIC)

  channelId Int
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  aiData VideoAI?
  metadata VideoMetadata?
  videoActions VideoAction[]

  createdAt DateTime @default(now())

  @@index([channelId])
  @@index([visibility])
  @@index([publicId]) // ✅ ADD THIS
}


model S3Credential {
  id         Int      @id @default(autoincrement())
  name       String
  accessKey  String
  secretKey  String
  region     String?
  endpoint   String?
  bucketName String

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
}

model VideoAI {
  id Int @id @default(autoincrement())

  videoId Int   @unique
  video   Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  transcript String?

  keywords String[]
  tags     String[]

  aiTitle       String?
  aiDescription String?

  status String @default("pending")

  createdAt DateTime @default(now())
}

model VideoAction {
  id Int @id @default(autoincrement())

  userId  Int
  videoId Int

  actionType VideoActionType

  commentText String?

  playlistId Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  playlist Playlist? @relation(fields: [playlistId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([videoId])
  @@index([userId])
  @@index([actionType])
}

model Playlist {
  id Int @id @default(autoincrement())

  name String

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  actions VideoAction[]

  createdAt DateTime @default(now())

  @@index([userId])
}

model VideoMetadata {
  id Int @id @default(autoincrement())

  videoId Int @unique
  video   Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  duration Int              // seconds
  totalFrames Int?          // total frame count

  width Int?
  height Int?

  aspectRatio String?       // e.g. "16:9"
  orientation Orientation?  // PORTRAIT / LANDSCAPE / SQUARE

  fps Float?

  hasAudio Boolean @default(false)

  videoCodec String?
  audioCodec String?

  deviceInfo String?        // e.g. "iPhone 13", "Canon EOS 80D"

  createdAt DateTime @default(now())
}

enum Orientation {
  PORTRAIT
  LANDSCAPE
  SQUARE
}

enum UploadStatus {
  UPLOADING
  UPLOADED
  FAILED
}

enum UploadSource {
  MANUAL
  S3_IMPORT
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum VideoActionType {
  LIKE
  DISLIKE
  COMMENT
  ADD_TO_PLAYLIST
  WATCH   
}

enum VideoVisibility {
  PUBLIC
  PRIVATE
}
